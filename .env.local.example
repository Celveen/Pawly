# 复制本文件为 .env.local 并填入你的 Key
DEEPSEEK_API_KEY=在这里粘贴你的key
PAWLY_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions

# 登录验证码哈希盐（生产环境务必改成随机长字符串，如 openssl rand -hex 32 生成）
AUTH_SECRET=

# 短信服务商（可选）：不配置则为开发模式，验证码直接随接口返回、显示在登录框里。
# 接入阿里云/腾讯云短信后填写，并在 lib/auth.ts 的 sendSms 中实现真实发送。
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=
